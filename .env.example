# macOS Setup — Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is optional — package installation works without it.
# It is only required for features that need personal data:
#   - Git identity (git config)
#   - Hostname configuration

# ---------------------------------------------------------------------------
# Git — Personal profile
# Used by: Setup Git > Setup personal git config
# ---------------------------------------------------------------------------
PERSONAL_NAME="Your Name"
PERSONAL_EMAIL="you@personal.com"

# ---------------------------------------------------------------------------
# Git — Work profile
# Used by: Setup Git > Setup work git config
# ---------------------------------------------------------------------------
WORK_NAME="Your Name"
WORK_EMAIL="you@company.com"

# ---------------------------------------------------------------------------
# System
# Used by: System > Set hostname
# ---------------------------------------------------------------------------
HOSTNAME="my-macbook"
